{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "builds": [
    { "src": "public/**", "use": "@vercel/static" },
    { "src": "api/transcript.py", "use": "@vercel/python" }
  ],
  "routes": [
    { "src": "/api/transcript", "dest": "/api/transcript.py" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
